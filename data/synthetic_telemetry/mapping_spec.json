{
  "task": "refactor_telemetry_labeling",
  "objective": "Replace synthetic tower_1..tower_20 labels with meaningful component labels and derive the infrastructure tower layer while preserving all telemetry events and structure.",
  
  "input_labels": ["tower_1", "tower_2", "tower_3", "tower_4", "tower_5", "tower_6", "tower_7", "tower_8", "tower_9", "tower_10", "tower_11", "tower_12", "tower_13", "tower_14", "tower_15", "tower_16", "tower_17", "tower_18", "tower_19", "tower_20"],

  "output_labels": {
    "Compute": ["Cluster-A", "Cluster-B", "Cluster-C"],
    "Network": ["Core-Switch-1", "Edge-Router-2", "LoadBalancer-3"],
    "Storage": ["SAN-1", "NAS-2", "ObjectStore-3"],
    "Application": ["Payments", "Orders", "Inventory", "EmailService", "RecommendationService"]
  },

  "constraints": {
    "no_data_loss": true,
    "no_event_filtering": true,
    "only_modify_label_field": true,
    "deterministic_mapping": true,
    "configurable_mapping": true
  },

  "mapping_rules": {
    "strategy": "balanced_representation",
    "description": "Map tower_1..tower_20 to output labels using a deterministic lookup table while ensuring approximately uniform distribution across output labels unless strongly contradicted by input distribution.",
    "avoid_bias": true,
    "avoid_overrepresentation": true
  },

  "implementation_requirements": {
    "use_lookup_table": true,
    "externalize_config": "optional_yaml_or_json",
    "preserve_original_volume": true,
    "do_not_modify_other_fields": true
  },

  "output": {
    "return_type": "code_diff_or_patch",
    "include_explanation": true,
    "explanation_focus": "mapping_strategy_and_balance"
  }
}
